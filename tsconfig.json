{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2023"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src", "tidepool.config.ts", "vitest.config.ts"],
  "//exclude": "infra/pulumi is a standalone Node/Pulumi package with its own tsconfig + deps (@pulumi/*); keep it out of the Bun root typecheck.",
  "exclude": ["infra/pulumi"]
}
