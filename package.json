{
  "name": "tidepool",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2"
  },
  "bin": {
    "tp": "./src/cli.ts"
  },
  "scripts": {
    "format": "biome format --write .",
    "format:sh": "shfmt -w -i 2 -ci .claude/hooks/*.sh infra/scripts/*.sh infra/bootstrap/*.sh",
    "lint": "biome check .",
    "lint:sh": "shellcheck .claude/hooks/*.sh infra/scripts/*.sh infra/bootstrap/*.sh && shfmt -d -i 2 -ci .claude/hooks/*.sh infra/scripts/*.sh infra/bootstrap/*.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun --bun vitest run",
    "commitlint": "commitlint --last --verbose",
    "kube": "bash infra/scripts/tp-kubeconfig.sh",
    "seal:hashes": "bash infra/scripts/redaction-hashes.sh",
    "check:secrets": "bash infra/scripts/redaction-hashes.sh --check",
    "check": "biome check . && bun run lint:sh && bun run typecheck && bun run test",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.17.11",
    "effect": "3.21.4",
    "@effect/platform": "0.96.2",
    "@effect/platform-bun": "0.90.0",
    "@effect/cli": "0.75.2",
    "@effect/experimental": "0.60.0",
    "@effect/sql": "0.51.1",
    "@effect/sql-pg": "0.52.1",
    "@effect/sql-sqlite-bun": "0.52.0",
    "@octokit/rest": "22.0.1",
    "nanoid": "5.1.16"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@effect/vitest": "0.29.0",
    "@types/bun": "1.3.14",
    "fast-check": "4.8.0",
    "lefthook": "2.1.9",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
