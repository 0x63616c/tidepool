{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/sops-leak-guard.sh\"",
            "timeout": 10,
            "statusMessage": "sops-leak-guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/age-key-tripwire.sh\"",
            "timeout": 10,
            "statusMessage": "age-key-tripwire"
          }
        ]
      }
    ]
  }
}
