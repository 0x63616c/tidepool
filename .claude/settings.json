{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/secret-command-guard.sh\"",
            "timeout": 10,
            "statusMessage": "secret-command-guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/secret-redactor.sh\"",
            "timeout": 15,
            "statusMessage": "secret-redactor"
          }
        ]
      }
    ]
  }
}
