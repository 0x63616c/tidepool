node_modules/
dist/
*.tsbuildinfo
.DS_Store

# local state — never committed (runtime store lives on the main box volume)
*.sqlite
*.sqlite-*
.tidepool/
transcripts/

# decrypted secrets / bootstrap plaintext — never committed
secrets/*.dec.*
*.plaintext
.bootstrap/

# Pulumi
infra/**/Pulumi.*.yaml
# ...except the cluster's production stack config (non-secret; needed by CI apply).
!infra/pulumi/cluster/Pulumi.production.yaml
infra/**/.pulumi/
infra/pulumi/**/bin/

# agent skills — local ergonomics, regenerable via SKILLS.md (not product source)
# .agents/skills/ holds the real files; .claude/skills is a symlink into it so
# Claude Code + opencode both auto-discover them.
.agents/
# Only the local-ergonomics bits of .claude/ are ignored; .claude/settings.json +
# .claude/hooks/ are TRACKED so CI / other machines / PR-builders share the guards.
.claude/skills
.claude/worktrees/


# stray agent scratch output (session temp) — never commit
scratchpad/
