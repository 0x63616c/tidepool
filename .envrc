# Auto-load the sops/age decryption key from the macOS login keychain.
#
# Why keychain (not `op read` directly): the 1Password CLI re-authenticates per
# process, so a bare `op read` here costs one Touch ID per shell. The login
# keychain caches the key on-device and reads are silent — no per-shell prompt.
# 1Password stays the backup/source of record; this is just the runtime cache.
#
# First load on a machine seeds the keychain from 1Password (one Touch ID); every
# load after is promptless. We store only the `AGE-SECRET-KEY-` line (~74 chars):
# the op credential also carries `# created` / `# public key` comment lines, and
# the keychain's interactive writer truncates input at 128 chars — the key line
# alone is all SOPS_AGE_KEY needs and stays well under that.
#
# Login keychain is on-device only (NOT iCloud-synced), so the key never leaves
# this machine — consistent with tenet 9 (secrets stay home).
#
# Re-seed after rotating the breakglass key:
#   security delete-generic-password -s tidepool-age-breakglass
# Adjust the op:// path to your own vault if it differs.

keychain_svc="tidepool-age-breakglass"
SOPS_AGE_KEY="$(security find-generic-password -s "$keychain_svc" -w 2>/dev/null)"

if [ -z "$SOPS_AGE_KEY" ]; then
  # Seed once from 1Password. printf is a shell builtin and the value is fed via
  # stdin, so the secret never appears in argv (`ps`) or shell history. `-w` with
  # no value reads the data twice (enter + retype) from stdin.
  age_key="$(op read 'op://tidepool/age-breakglass/credential' | grep '^AGE-SECRET-KEY-')"
  printf '%s\n%s\n' "$age_key" "$age_key" \
    | security add-generic-password -a "$USER" -s "$keychain_svc" -T /usr/bin/security -U -w
  unset age_key
  SOPS_AGE_KEY="$(security find-generic-password -s "$keychain_svc" -w 2>/dev/null)"
fi

export SOPS_AGE_KEY
unset keychain_svc

# Default kubectl to the tidepool cluster while in this repo, without hiding your
# other clusters. KUBECONFIG is a file list; kubectl merges them and resolves
# scalar fields (current-context) from the FIRST file — tidepool.yaml self-sets
# `current-context: admin@tidepool`, so it wins here while ~/.kube/config's
# contexts stay merged in and `kubectl config use-context` can still swap freely.
# Outside the repo, KUBECONFIG is unset → your normal ~/.kube/config default.
# Guarded on the file existing so a machine that hasn't run kubeconfig.sh yet
# (the script that writes it) keeps a working KUBECONFIG. Refresh: bun run kube.
if [ -f "$HOME/.kube/tidepool.yaml" ]; then
  export KUBECONFIG="$HOME/.kube/tidepool.yaml:${KUBECONFIG:-$HOME/.kube/config}"
fi
