# Auto-load the sops/age decryption key for this repo.
# Pulls the breakglass age key from 1Password (never stored on disk) and exports
# it as SOPS_AGE_KEY so `sops -d ...` just works in any shell under this dir.
# Touch ID prompts on first load per shell session; cached by the 1Password agent after.
# Adjust the op:// path to your own vault if it differs.
export SOPS_AGE_KEY="$(op read 'op://tidepool/age-breakglass/credential')"
